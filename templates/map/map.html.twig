{% extends 'layouts/layout.html.twig' %}

{% block title %}
    {{'map.meta.title'|trans}} - {{ parent() }}
{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {{ encore_entry_link_tags('map') }}
{% endblock %}

{% block body %}
    <div class="fr-x-container--fluid fr-x-h-full">
        <div class="fr-grid-row fr-x-h-full">
            <div class="fr-col-12 fr-col-sm-4 fr-col-md-3 fr-container fr-pt-2w fr-pb-6w">
                {% if not app.request.query.get('embed') %}
                    <h1 class="fr-h4">{{ 'map.title'|trans }}</h1>
                    <div class="fr-my-2w">
                        <d-map-search-form target="map">
                            {% include 'map/_search_form.html.twig' with {} only %}
                        </d-map-search-form>
                    </div>
                {% endif %}

                <div class="fr-accordion">
                    <h2 class="fr-accordion__title">
                        <button class="fr-accordion__btn" aria-expanded="true" aria-controls="map-filters-accordion">
                            <span class="fr-icon-filter-line fr-icon--sm fr-mr-1w" aria-hidden="true"></span>{{ 'map.filters.title'|trans }}
                        </button>
                    </h2>
                    <div class="fr-collapse fr-collapse--expanded" id="map-filters-accordion">
                        <h3 class="fr-h6 fr-my-2w">{{ 'map.filters.title.restriction'|trans }}</h3>
                        <d-map-form target="map" urlAttribute="tilesUrl" class="fr-x-block fr-mb-2w">
                            {{ form_start(form, {
                                attr: {
                                    class: 'd-stack',
                                    style: '--stack-gap: var(--1w)',
                                },
                            }) }}
                            <fieldset class="fr-fieldset" id="measureTypes" aria-labelledby="measureTypes-legend">
                                {{ form_label(form.measureTypes, null, {
                                    element: 'legend',
                                    label_attr: { id: 'measureTypes-legend', class: 'fr-fieldset__legend fr-fieldset__legend--regular' },
                                }) }}
                                {% for child in form.measureTypes %}
                                        <div class="fr-checkbox-group fr-ml-1w fr-mb-1w">
                                            {{ form_widget(child) }}
                                            <label class="fr-label map-filter-label map-filter-label--{{ child.vars.value }}" for="{{ child.vars.id }}">
                                                {{ child.vars.label|trans }}
                                            </label>
                                        </div>
                                {% endfor %}
                                
                            </fieldset>

                            <h4 class="fr-h6 fr-my-2w">{{ 'map.filters.title.vehicles'|trans }}</h4>
                            <div class="fr-toggle fr-toggle--label-left">
                                {{ form_widget(form.displayHeavyGoodsVehicles, {attr: {class: 'fr-toggle__input'}}) }}
                                <label class="fr-toggle__label map-vehicle-toggle__label" for="{{ form.displayHeavyGoodsVehicles.vars.id }}"
                                    data-fr-checked-label="{{ 'map.toggle.enabled'|trans }}"
                                    data-fr-unchecked-label="{{ 'map.toggle.disabled'|trans }}">
                                    <svg class="fr-artwork map-vehicle-artwork" aria-hidden="true" viewBox="0 0 26 19" width="26" height="19">
                                        <use class="fr-artwork-major" xlink:href="{{ asset('images/restriction/all_vehicles.no.svg') }}#artwork-major"></use>
                                    </svg>
                                    {{ 'map.filter.heavy_goods_vehicles'|trans }}
                                </label>
                            </div>

                            <h4 class="fr-h6 fr-my-2w">{{ 'map.filters.title.type.regulation'|trans }}</h4>
                            {{ form_row(form.displayPermanentRegulations, {group_class: 'fr-checkbox-group', row_attr: {class: 'fr-mb-2w'}}) }}
                            {{ form_row(form.displayTemporaryRegulations, {group_class: 'fr-checkbox-group'}) }}

                            {% if app.user %}
                                <h4 class="fr-h6 fr-mt-3w fr-mb-2w">{{ 'map.filters.title.status'|trans }}</h4>
                                {{ form_row(form.displayPublished, {group_class: 'fr-checkbox-group', row_attr: {class: 'fr-mb-2w'}}) }}
                                {{ form_row(form.displayDrafts, {group_class: 'fr-checkbox-group'}) }}
                            {% else %}
                                {# "Statut des arrêtés" is reserved to logged-in users. Mark the fields
                                   as rendered so form_end() does not auto-render them (unstyled) for
                                   anonymous visitors — while still letting it render the CSRF token. #}
                                {% do form.displayPublished.setRendered %}
                                {% do form.displayDrafts.setRendered %}
                            {% endif %}

                            <h4 class="fr-h6 fr-mt-3w fr-mb-2w">{{ 'map.filters.title.application.period'|trans }}</h4>
                            {{ form_row(form.startDate, {group_class: 'fr-input-group', widget_class: 'fr-input'}) }}
                            {{ form_row(form.endDate, {group_class: 'fr-input-group', widget_class: 'fr-input'}) }}

                            <noscript>
                                {{ form_row(form.save) }}
                            </noscript>
                            {{ form_end(form) }}
                        </d-map-form>
                    </div>
                </div>
            </div>

            <d-map
                id="map"
                class="fr-col-12 fr-col-sm-8 fr-col-md-9 d-map-with-share"
                aria-hidden="true"
                mapHeight="100%"
                mapMinHeight="600px"
                mapPos="[2.725, 47.16]"
                mapZoom="5"
                tilesUrl="{{ tilesUrlTemplate }}"
                {% if initialBbox %}initialBbox="{{ initialBbox|json_encode }}"{% endif %}
                {% if app.user %}draftsUrl="{{ path('app_carto_drafts_data') }}"{% endif %}
                locationPopupUrl="{{ path('fragment_map_location') }}"
            >
                <p data-map-hidewhen="ready" class="fr-mt-5w fr-x-text--center">
                    {{ 'map.loading'|trans }}
                </p>
                {% if app.user and not app.request.query.get('embed') %}
                    {% include 'map/_share.html.twig' with {
                        organizations: app.user.userOrganizations,
                        carteUrl: url('app_carto'),
                    } only %}
                {% endif %}
            </d-map>
        </div>
    </div>
{% endblock %}
