{% if not canDelete %}
    {% for measureUuid in measureUuids %}
        <turbo-stream action="replace" target="measure_{{ measureUuid }}_delete_button">
            <template>
                <li id="measure_{{ measureUuid }}_delete_button"></li>
            </template>
        </turbo-stream>
    {% endfor %}
{% endif %}

<turbo-stream action="remove" target="block_measure_{{ uuid }}"></turbo-stream>

<turbo-stream action="update" target="block_publication">
    <template>
        {% include 'regulation/fragments/_publication_button.html.twig' with { canPublish: true, uuid: regulationOrderRecordUuid, regulationOrderRecord, publishLabel: 'regulation.publish_changes'|trans } only %}
    </template>
</turbo-stream>
