{% extends 'email/base.html.twig' %}
{% trans_default_domain 'emails' %}

{% block body %}
    <p>{{ 'welcome.email.hello'|trans }}</p>
    <p>{{ 'welcome.email.description'|trans }}</p>
    <ul class="fr-btns-group fr-btns-group--inline fr-btns-group--right fr-mt-3w">
        <li>
            ℹ️ {{ 'welcome.email.help'|trans|raw }}
            <a href="https://fabrique-numerique.gitbook.io/doc.dialog.beta.gouv.fr" role="button" class="fr-btn fr-btn--tertiary">
                {{ 'welcome.email.help.link'|trans }}
            </a>
        </li>
        <li>
            🎬 {{ 'welcome.email.how.create.regulation.order.video'|trans|raw }}
            <a href="https://tube.numerique.gouv.fr/w/ry5FweKbZuU2ddNpMm6LNU" role="button" class="fr-btn fr-btn--icon-right fr-icon-youtube-line">
                {{ 'welcome.email.how.create.regulation.order.video.link'|trans }}
            </a>
        </li>
        <li>
            📬 {{ 'welcome.email.contact'|trans|raw }}
        </li>
    </ul>
    <p>{{ 'welcome.email.feedback'|trans }}</p>
    <div class="fr-notice fr-notice--info fr-mt-3w">
        <div class="fr-container">
            <div class="fr-notice__body">
                <p>
                    <span class="fr-notice__title fr-icon-calendar-event-line">{{ 'welcome.email.webinar.title'|trans }}</span>
                    <br>
                    <span class="fr-notice__desc">{{ 'welcome.email.webinar.description'|trans }}</span>
                    <a title="{{ 'welcome.email.webinar.link'|trans }}" href="https://visio.numerique.gouv.fr/ogx-uujt-vsi" target="_blank" rel="noopener external" class="fr-notice__link">{{ 'welcome.email.webinar.link'|trans }}</a>
                </p>
            </div>
        </div>
    </div>
    <p>{{ 'welcome.email.signature'|trans }}</p>
{% endblock %}
